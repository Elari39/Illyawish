# Optional AI fallback
# Used only when the current user has no active AI provider preset.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key
MODEL=gpt-4.1-mini

# Optional backend defaults
APP_ENV=development
SQLITE_PATH=./backend/data/aichat.db
UPLOAD_DIR=./backend/data/uploads
SERVER_PORT=5721
SESSION_SECRET=change-me-session-secret
SETTINGS_ENCRYPTION_KEY=change-me-settings-encryption-key
FRONTEND_ORIGIN=http://localhost:10170

# Optional first-user bootstrap
# If omitted and the database has no users, the frontend will guide you through first-user setup.
BOOTSTRAP_USERNAME=
BOOTSTRAP_PASSWORD=
